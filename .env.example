# Port the server listens on (default 3000)
PORT=3000

# Optional: a shared secret clients must send in the Authorization header.
# Set this and protect your deployed server. Example: a long random string.
# MCP_API_KEY=your-secret-key-here

# --- Google Auth (pick one approach) ---

# Option A: Service Account JSON key file path (recommended for personal use)
# 1. Create a service account in Google Cloud Console
# 2. Enable the Google Sheets API
# 3. Download the JSON key and set the path here
# 4. Share your spreadsheets with the service account email
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Option B: Inline service account credentials (better for hosted deployments)
# Paste the entire JSON key as a single line
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
